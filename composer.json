{
    "name": "phpx/webassembly-packer",
    "description": "WebAssembly file packager with LZ4 compression support",
    "type": "project",
    "require": {
        "php": ">=8.1",
        "syntaxx/phpx-lz4": "dev-main"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0",
        "symfony/process": "^6.0",
        "mck89/peast": "dev-master"
    },
    "autoload": {
        "psr-4": {
            "Tests\\": "tests/",
            "PHPX\\WebAssemblyPacker\\": "src/"
        }
    },
    "minimum-stability": "dev"
}
