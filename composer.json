{
    "name": "syntaxx/webassembly-packer",
    "description": "WebAssembly file packager with LZ4 compression support",
    "type": "project",
    "bin": [
        "bin/file-packager"
    ],
    "require": {
        "php": ">=8.1",
        "syntaxx/lz4": "dev-main"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0",
        "symfony/process": "^6.0"
    },
    "autoload": {
        "psr-4": {
            "Tests\\": "tests/",
            "Syntaxx\\WebAssemblyPacker\\": "src/"
        }
    },
    "minimum-stability": "dev"
}
